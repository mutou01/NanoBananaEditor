# Image Generation Provider Configuration
# Supported providers: gemini, openai, custom
VITE_IMAGE_PROVIDER=openai

# =============================================================================
# Gemini Provider Configuration (default)
# =============================================================================
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash-image-preview

# =============================================================================
# OpenAI / Custom Provider Configuration
# Use these when VITE_IMAGE_PROVIDER is set to 'openai' or 'custom'
# =============================================================================
VITE_IMAGE_API_URL=https://freeapi.dgbmc.top/v1/images/generations
VITE_IMAGE_API_KEY=sk-gz05xF8kN1Cq6LFLUy1UhDlTa0soVALwsAZ0lbUoCSzuoO2p
VITE_IMAGE_MODEL=gpt-image-2

# =============================================================================
# Default Generation Parameters (optional)
# =============================================================================
# Default image size: 1024x1024, 1024x1536, 1536x1024, auto
VITE_IMAGE_DEFAULT_SIZE=1024x1024
# Default temperature (0.0 - 1.0, affects creativity/quality tradeoff)
VITE_IMAGE_DEFAULT_TEMPERATURE=0.7
# Default number of images to generate per request
VITE_IMAGE_DEFAULT_N=1

# =============================================================================
# Notes
# =============================================================================
# - In production, API calls should go through a backend proxy
# - VITE_IMAGE_PROVIDER determines which provider to use:
#   * 'gemini': Use Google's Gemini 2.5 Flash Image model
#   * 'openai': Use OpenAI DALL-E or GPT-Image models
#   * 'custom': Use any OpenAI-compatible API endpoint
# - Set the corresponding provider's API key and configuration
# - Do not commit actual API keys to version control
